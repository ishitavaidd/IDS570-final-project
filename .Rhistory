summarize(total_contribution = sum(contribution_receipt_amount, na.rm = TRUE)) %>%
mutate(type = "Private University")
public_total <- public_finances %>%
summarize(total_contribution = sum(contribution_receipt_amount, na.rm = TRUE)) %>%
mutate(type = "Public University")
community_total <- community_finances %>%
summarize(total_contribution = sum(contribution_receipt_amount, na.rm = TRUE)) %>%
mutate(type = "Community College")
#combine total contributions
combined_totals <- bind_rows(private_total, public_total, community_total)
# total graphs
combined_totals <- combined_totals %>%
mutate(type = factor(type, levels = c("Private University", "Public University", "Community College")))
ggplot(combined_totals, aes(x = type, y = total_contribution, fill = type)) +
geom_col() +
scale_fill_manual(values = c("Private University" = "lightblue", "Public University" = "navyblue", "Community College" = "steelblue")) +
scale_y_continuous(labels = label_number(scale_cut = cut_short_scale())) +
labs(title = "Total Political Contributions by Institution Type",
x = "Institution Type",
y = "Total Contribution Amount ($)") +
theme_minimal() +
scale_y_continuous(labels = scales::comma)
print(combined_totals)
other_donations_filtered <- other_donations %>% filter(other_parties %in% c("Democratic", "Republican"))
public_other_donations_filtered <- public_other_donations %>% filter(other_parties %in% c("Democratic", "Republican"))
community_other_donations_filtered <- community_other_donations %>% filter(other_parties %in% c("Democratic", "Republican"))
other_donations_filtered$type <- "Private University"
public_other_donations_filtered$type <- "Public University"
community_other_donations_filtered$type <- "Community College"
combined_donations <- bind_rows(other_donations_filtered,
public_other_donations_filtered,
community_other_donations_filtered)
# Make sure the type order is Private, Public, Community
combined_donations$type <- factor(combined_donations$type,
levels = c("Private University", "Public University", "Community College"))
# Plot
ggplot(combined_donations, aes(x = type, y = total_contribution, fill = other_parties)) +
geom_col(position = "dodge") +
labs(title = "Political Contributions by Institution Type and Party",
x = "Institution Type",
y = "Total Contribution Amount ($)",
fill = "Party") +
theme_minimal() +
scale_y_continuous(labels = scales::comma) +
scale_fill_manual(values = c("Democratic" = "navyblue", "Republican" = "red"))
print(combined_donations)
# Total number of donations
x_total <- nrow(community_finances)
# Number of donations less than or equal to $200
y_under_200 <- sum(community_finances$contribution_receipt_amount <= 200)
# Print results
cat("Out of", x_total, "donations,", y_under_200, "were $200 or less.\n")
# Total number of donations
x_total <- nrow(private_finances)
# Number of donations less than or equal to $200
y_under_200 <- sum(private_finances$contribution_receipt_amount <= 200)
# Print results
cat("Out of", x_total, "donations,", y_under_200, "were $200 or less.\n")
# Total number of donations
x_total <- nrow(public_finances)
# Number of donations less than or equal to $200
y_under_200 <- sum(public_finances$contribution_receipt_amount <= 200)
# Print results
cat("Out of", x_total, "donations,", y_under_200, "were $200 or less.\n")
# Create a simple dataframe
df <- data.frame(
group = c("Community Colleges", "Private Institutions", "Public Universities"),
less_200 = c(524, 11178, 3210),
more_200 = c(32, 3675, 655)
)
library(tidyr)
df_long <- pivot_longer(df, cols = c(less_200, more_200), names_to = "amount_type", values_to = "count")
df_long$amount_type <- recode(df_long$amount_type,
less_200 = "Small Donations (<$200)",
more_200 = "Large Donations (>$200)")
library(ggplot2)
ggplot(df_long, aes(x = group, y = count, fill = amount_type)) +
geom_bar(stat = "identity") +
scale_fill_manual(values = c("Small Donations (<$200)" = "navyblue", "Large Donations (>$200)" = "yellow")) +
labs(title = "Donation Amounts by Individuals",
x = "Institution Type",
y = "Number of Donations",
fill = "Donation Size") +
theme_minimal()
print(df)
state_info <- read_csv("/Users/Ishita/Desktop/Labs_CSS/state_info.csv")
# Just stack them together
combined_data <- bind_rows(public_contribution_party, community_contribution_party, contribution_party)
print(combined_data)
# Merge combined_data with state_info by 'contributor_employer'
merged_data <- left_join(combined_data, state_info, by = "contributor_employer")
print(merged_data)
filtered_data <- merged_data %>%
filter(party_name.x %in% c("Democratic", "Republican"))
print(filtered_data)
filtered_data <- filtered_data %>%
mutate(party_name.x = ifelse(party_name.x == "Democratic", "Democrat", party_name.x))
state_party_summary <- filtered_data %>%
group_by(state_name, party_name.x, election_result) %>%
summarise(total_contribution = sum(total_contribution, na.rm = TRUE), .groups = "drop")
# Step 2: Pivot wider so Democrat and Republican are separate columns
state_wide <- state_party_summary %>%
pivot_wider(
names_from = party_name.x,
values_from = total_contribution,
values_fill = 0  # If a party is missing in a state, fill with 0
)
# Step 3: Calculate Democrat-to-Republican ratio
state_wide <- state_wide %>%
mutate(dem_to_rep_ratio = Democrat / Republican)
# View the result
print(state_wide)
# Ensure necessary library is loaded
library(dplyr)
test_data <- state_wide %>%
filter(!is.infinite(dem_to_rep_ratio) & !is.na(dem_to_rep_ratio))
t_test_result <- t.test(
dem_to_rep_ratio ~ election_result,
data = test_data,
alternative = "greater"  # Because you're testing if Blue > Red
)
print(t_test_result)
